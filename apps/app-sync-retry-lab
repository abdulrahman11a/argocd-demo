apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: app-sync-retry-lab
  namespace: argocd

spec:
  project: default

  source:
    repoURL: https://github.com/abdulrahman11a/argocd-demo.git
    targetRevision: main
    path: overlays/production

  destination:
    server: https://kubernetes.default.svc
    namespace: default

  syncPolicy:
    automated:
      prune: true
      selfHeal: true

    # Retry configuration for failed sync operations
    # limit: maximum number of retry attempts
    # backoff: controls delay between retries (exponential backoff strategy)
    retry:
      limit: 3
      backoff:
        duration: 10s
        factor: 2
        maxDuration: 2m

    syncOptions:
      - CreateNamespace=true
